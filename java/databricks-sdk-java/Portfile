PortSystem          1.0
PortGroup           java 1.0
PortGroup           github 1.0

github.setup        databricks databricks-sdk-java 0.103.0 v
name                databricks-sdk-java
revision            0

categories          java devel
license             Apache-2
supported_archs     noarch
maintainers         nomaintainer

description         Databricks SDK for Java

long_description    The Databricks SDK for Java includes functionality to accelerate \
                    development with Java for the Databricks Lakehouse. It covers all \
                    public Databricks REST API operations and provides a unified \
                    authentication experience with support for OAuth, PAT, and other \
                    Databricks-native credential providers.

homepage            https://docs.databricks.com/dev-tools/sdk-java.html

java.version        8+
java.fallback       openjdk11

set sdk_name        databricks-sdk-java

master_sites        https://github.com/databricks/databricks-sdk-java/releases/download/v${version}/
distfiles           ${sdk_name}-${version}.jar \
                    ${sdk_name}-${version}-sources.jar \
                    ${sdk_name}-${version}-javadoc.jar

checksums           ${sdk_name}-${version}.jar \
                    rmd160  c4861c059aa6cff622793172af94b0d08cfc50ba \
                    sha256  a1f5a5ff5b5cb2407990ac6c9a3d02fc69a4c08b790a9fe02098e20d293e555f \
                    size    4799354 \
                    ${sdk_name}-${version}-sources.jar \
                    rmd160  ddcb461c14a1a52c0be7cd14c9553fe1b73413dd \
                    sha256  04d6c6cbc846815e48963ca78c4f236e915dc4307c9b912385d1d7e05afb8235 \
                    size    3472772 \
                    ${sdk_name}-${version}-javadoc.jar \
                    rmd160  c9dd9ba0fce1345843b574c26c5c3e70ca3fe9c4 \
                    sha256  6d28b97645c08cf4754a95fb44b8a8020d600de7a7fba48fa02cc6326143a11c \
                    size    19896793

extract.cmd         unzip
extract.pre_args    -q
extract.post_args   -d ${workpath}/api
extract.only        ${sdk_name}-${version}-javadoc.jar

use_configure       no

build {}

destroot {
    set javadir ${destroot}${prefix}/share/java
    set docdir ${destroot}${prefix}/share/doc/${name}

    xinstall -d ${javadir} ${docdir}

    file copy ${distpath}/${sdk_name}-${version}.jar \
        ${javadir}/${sdk_name}.jar
    file copy ${distpath}/${sdk_name}-${version}-sources.jar \
        ${javadir}/${sdk_name}-sources.jar

    file copy ${workpath}/api ${docdir}
}

notes "
The Databricks SDK for Java JARs have been installed to:

    ${prefix}/share/java/${sdk_name}.jar
    ${prefix}/share/java/${sdk_name}-sources.jar

Add them to your classpath to use in your Java projects.
API documentation is available at:

    ${prefix}/share/doc/${name}/api/
"
